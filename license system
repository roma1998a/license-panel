const express = require('express');
const router = express.Router();

let licenses = [];

function genKey(){
    return 'LIC-' + Math.random().toString(36).substring(2,10).toUpperCase();
}

// create
router.post('/create',(req,res)=>{
    const {type} = req.body;

    let days = 1;
    if(type === 'weekly') days = 7;
    if(type === 'monthly') days = 30;

    const key = genKey();
    const exp = new Date();
    exp.setDate(exp.getDate()+days);

    const lic = {
        key,
        type,
        expires: exp,
        active:true
    };

    licenses.push(lic);

    res.json(lic);
});

// list
router.get('/all',(req,res)=>{
    res.json({total:licenses.length,data:licenses});
});

// disable
router.post('/disable',(req,res)=>{
    const {key} = req.body;

    const lic = licenses.find(l=>l.key===key);
    if(lic) lic.active=false;

    res.json({success:true});
});

// check API
router.post('/check',(req,res)=>{
    const {key} = req.body;

    const lic = licenses.find(l=>l.key===key);

    if(!lic) return res.json({valid:false});

    if(!lic.active) return res.json({valid:false});

    if(new Date() > lic.expires) return res.json({valid:false});

    res.json({valid:true,license:lic});
});

module.exports = router;
